@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(TAGVAL_WITH_NLOHMANN_JSON @TAGVAL_WITH_NLOHMANN_JSON@)
set(TAGVAL_WITH_PARCEL @TAGVAL_WITH_PARCEL@)

# commons is a mandatory core dependency: tagval always links commons::commons.
find_dependency(commons 0.1.3)

if(TAGVAL_WITH_NLOHMANN_JSON)
    find_dependency(nlohmann_json 3.12.0)
endif()

if(TAGVAL_WITH_PARCEL)
    find_dependency(parcel 0.2.0)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/tagvalTargets.cmake")

check_required_components(tagval)
